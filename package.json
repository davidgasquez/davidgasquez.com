{
  "name": "davidgasquez.com",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": "22.16.0"
  },
  "scripts": {
    "update-handbook": "rm -rf src/content/handbook && git clone --depth=1 https://github.com/davidgasquez/handbook.git src/content/handbook",
    "dev": "npm run update-handbook && astro dev --host 0.0.0.0",
    "start": "astro dev",
    "build": "npm run update-handbook && astro check && astro build && npx pagefind --site dist",
    "preview": "astro preview",
    "preview:worker": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "sync-standard": "node --env-file-if-exists=.env scripts/sync-standard.mjs --apply",
    "sync-standard:dry": "node --env-file-if-exists=.env scripts/sync-standard.mjs --dry-run",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdown-satteri": "^0.3.2",
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@duckdb/node-api": "^1.5.4-r.1",
    "astro": "^7.0.3",
    "satteri": "^0.9.3",
    "sharp": "^0.35.2",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "pagefind": "^1.5.2",
    "prettier": "^3.8.5",
    "prettier-plugin-astro": "^0.14.1",
    "wrangler": "^4.105.0"
  }
}

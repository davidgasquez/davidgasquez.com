---
import Layout from "../layouts/Base.astro";

import { Image } from "astro:assets";
import avatar from "../assets/avatar.jpg";
---

<Layout>
  <div class="container py-xl">
    <div class="text-center mb-xl">
      <Image src={avatar} alt="David" class="mx-auto avatar-hex mb-lg" height={220} width={220} />
    </div>

    <section class="mb-xl">
      <h2 class="font-semibold text-2xl mb-md">About</h2>
      <p>
        I'm David. I work as the one person data team at <a class="accent-link" href="https://protocol.ai/"
          >Protocol Labs</a
        >.
      </p>
      <p>
        I build data systems for open networks, public goods, and communities. I care about making data useful for
        people.
      </p>
      <p>
        I write about <a class="accent-link" href="/modern-open-data-portals">open data portals</a>,
        <a class="accent-link" href="/barefoot-data-platforms">local friendly data projects</a>,
        <a class="accent-link" href="/ranking-with-agents">making agents more reliable</a>, and
        <a class="accent-link" href="/handbook">I share tons of notes I write while learning</a>.
      </p>
    </section>

    <section class="mb-xl">
      <h2 class="font-semibold text-2xl mb-md">Working on:</h2>
      <ul class="list-inside list-disc">
        <li>Data platforms and open datasets</li>
        <li>Public goods funding and impact evaluation</li>
        <li>Agentic engineering and AI assisted data work</li>
        <li>Decentralized protocols and open infrastructure</li>
      </ul>
    </section>

    <section class="mb-xl">
      <h2 class="font-semibold text-2xl mb-md">Values</h2>
      <ul class="list-inside list-disc">
        <li>Keep systems small and understandable</li>
        <li>Prefer plain files, open tools, and reproducible workflows</li>
        <li>Write things down so others and future me can build on them</li>
        <li>Start with experiments and tighten the feedback loop</li>
      </ul>
    </section>

    <section class="mb-xl">
      <div class="text-center my-lg">
        <a
          class="accent-link"
          href="https://github.com/davidgasquez/"
          target="_blank"
          rel="noopener noreferrer"
          title="Github">GitHub</a
        >
        ·
        <a
          class="accent-link"
          href="https://bsky.app/profile/davidgasquez.com"
          target="_blank"
          rel="noopener noreferrer"
          title="Bluesky">Bluesky</a
        >
        ·
        <a class="accent-link" href="https://x.com/davidgasquez" target="_blank" rel="noopener noreferrer" title="X"
          >X</a
        >
        ·
        <a
          class="accent-link"
          href="https://www.linkedin.com/in/davidgasquez/"
          target="_blank"
          rel="noopener noreferrer"
          title="Linkedin">LinkedIn</a
        >
        ·
        <a
          class="accent-link"
          href="mailto:davidgasquez@gmail.com"
          target="_blank"
          rel="noopener noreferrer"
          title="Email">Email</a
        >
        ·
        <a
          class="accent-link"
          href="https://open.spotify.com/user/kalendos"
          target="_blank"
          rel="noopener noreferrer"
          title="Spotify">Spotify</a
        >
      </div>
    </section>

    <section class="mb-xl">
      <h2 class="font-semibold text-2xl mb-md">Interests</h2>
      <ul class="list-inside list-disc">
        <li>Open data and public goods</li>
        <li>Agentic engineering</li>
        <li>Decentralized protocols (AT Protocol, Blockchains, ...)</li>
        <li>Tools for thought</li>
        <li>Games, music, and learning odd things</li>
      </ul>
    </section>
  </div>
</Layout>

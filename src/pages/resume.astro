---
const contacts = [
  ["GitHub", "https://github.com/davidgasquez"],
  ["Bluesky", "https://bsky.app/profile/davidgasquez.com"],
  ["X", "https://X.com/davidgasquez"],
  ["LinkedIn", "https://www.linkedin.com/in/davidgasquez/"],
  ["Website", "https://davidgasquez.com/"],
  ["Email", "mailto:davidgasquez@gmail.com"],
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Resume for David Gasquez, staff data engineer working on data platforms, analytics, open data, and distributed teams."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;650;700&display=swap" rel="stylesheet" />
    <title>David Gasquez · Resume</title>

    <style>
      :root {
        --ink: #24292e;
        --muted: #6a737d;
        --accent: #770000;
        --rule: #e6e6e6;
        --paper: #fdfdfc;
      }

      * {
        box-sizing: border-box;
      }

      html {
        background: var(--paper);
        color: var(--ink);
        font-family:
          Inter,
          ui-sans-serif,
          system-ui,
          -apple-system,
          BlinkMacSystemFont,
          "Segoe UI",
          sans-serif;
        font-size: 15px;
        line-height: 1.55;
        -webkit-font-smoothing: antialiased;
      }

      body {
        margin: 48px auto;
        padding: 0 32px;
        overflow-wrap: break-word;
      }

      a {
        color: var(--accent);
        text-decoration: none;
        text-underline-offset: 0.18em;
      }

      a:hover,
      a:focus-visible {
        text-decoration: underline;
      }

      a:focus-visible {
        outline: 2px solid rgba(119, 0, 0, 0.45);
        outline-offset: 3px;
      }

      .resume {
        margin-inline: auto;
        max-width: 760px;
      }

      h1,
      h2,
      h3,
      p,
      ul,
      dl {
        margin-block: 0;
      }

      h1,
      h2,
      h3 {
        font-weight: 650;
        line-height: 1.2;
      }

      h1,
      h2 {
        border-bottom: 1px solid var(--rule);
        padding-bottom: 0.32em;
      }

      h1 {
        font-size: clamp(2rem, 6vw, 2.7rem);
        letter-spacing: -0.035em;
      }

      h2 {
        color: #30363d;
        font-size: 1.35rem;
        letter-spacing: -0.015em;
        margin-top: 2rem;
      }

      h3 {
        font-size: 1.05rem;
      }

      p,
      ul,
      dl {
        margin-top: 0.75rem;
      }

      ul {
        padding-left: 1.5rem;
      }

      li + li {
        margin-top: 0.35rem;
      }

      .socials {
        align-items: center;
        display: flex;
        flex-wrap: wrap;
        font-size: 0.92rem;
        font-style: normal;
        gap: 0.35rem 0.7rem;
        margin-top: 0.85rem;
      }

      .socials a {
        color: var(--muted);
      }

      .socials a:hover,
      .socials a:focus-visible {
        color: var(--accent);
      }

      .separator {
        color: var(--rule);
      }

      .hero {
        margin-bottom: 1.75rem;
      }

      .intro {
        margin-top: 0.75rem;
      }

      .item {
        margin-top: 1.1rem;
      }

      .item > header {
        align-items: baseline;
        display: flex;
        flex-wrap: wrap;
        gap: 0.25rem 1rem;
        justify-content: space-between;
      }

      .meta {
        color: var(--muted);
        margin-top: 0;
      }

      .skills {
        display: grid;
        gap: 0;
        margin-top: 0.9rem;
      }

      .skills div {
        border-bottom: 1px solid var(--rule);
        display: grid;
        gap: 1.2rem;
        grid-template-columns: 9.25rem 1fr;
        padding: 0.55rem 0 0.6rem;
      }

      dt {
        color: #30363d;
        font-weight: 700;
      }

      dd {
        line-height: 1.65;
        margin: 0;
      }

      .projects {
        display: grid;
        gap: 0.35rem;
        list-style: none;
        padding: 0;
      }

      .projects p {
        display: inline;
        margin: 0;
      }

      .projects strong::after {
        content: ": ";
      }

      ::selection {
        background: #f2d8d8;
      }

      @media (max-width: 640px) {
        html {
          font-size: 14px;
        }

        body {
          margin: 24px auto;
          padding: 0 20px;
        }

        .skills div {
          display: block;
        }

        .skills dd {
          margin-top: 0.15rem;
        }
      }

      @media print {
        body {
          margin: 0;
          padding: 0;
        }

        .resume {
          margin-inline: 0;
          max-width: none;
        }

        a {
          color: var(--accent);
          text-decoration: none;
        }

        h2 {
          break-after: avoid;
        }

        article,
        li {
          break-inside: avoid;
        }
      }
    </style>
  </head>

  <body>
    <main class="resume">
      <header class="hero">
        <h1>David Gasquez</h1>
        <address class="socials" aria-label="Contact links">
          {
            contacts.map(([label, href], index) => (
              <>
                {index > 0 && (
                  <span class="separator" aria-hidden="true">
                    ·
                  </span>
                )}
                <a href={href}>{label}</a>
              </>
            ))
          }
        </address>
        <p class="intro">
          Data engineer passionate about open source, useful data platforms, analytics, and distributed teams. Currently
          helping <a href="https://protocol.ai/">Protocol Labs</a> coordinate better through data.
        </p>
      </header>

      <section aria-labelledby="experience">
        <h2 id="experience">Experience</h2>

        <article class="item">
          <header>
            <h3><a href="https://protocol.ai/">Protocol Labs</a></h3>
            <p class="meta"><time datetime="2022-03">Mar 2022</time> – Now</p>
          </header>
          <p><strong>Staff Data Engineer</strong> · 2024 – Now</p>
          <p>Own open BI and analytics infrastructure for the Filecoin ecosystem:</p>
          <ul>
            <li>
              Lead leadership-facing BI surfaces: the <a href="https://github.com/davidgasquez/filecoin-data-portal/"
                >Filecoin Data Portal</a
              >, Filecoin in Numbers, Filecoin Pulse, public datasets, Dune dashboards, dbt models, and reporting
              workflows.
            </li>
            <li>
              Own KPI reporting for FF OKRs, network OKRs, WBR/QBR, PMF, onboarding, paid activity, retrieval, FEVM/FOC,
              ecosystem health, and strategic planning.
            </li>
            <li>
              Analyze protocol and ecosystem changes by combining KPI trends, stakeholder feedback, and explicit causal
              assumptions into decision-ready artifacts.
            </li>
            <li>
              Maintain a low-cost, open, reproducible data stack serving hundreds of daily dashboard visits and
              thousands of weekly public dataset reads.
            </li>
            <li>
              Define metric semantics, data quality expectations, caveats, and source-of-truth models across fragmented
              on-chain and off-chain data providers.
            </li>
          </ul>

          <p><strong>Sr. Data Engineer</strong> · 2022 – 2024</p>
          <p>Built the foundations for Protocol Labs' Filecoin analytics platform:</p>
          <ul>
            <li>
              Built and operated high-volume Filecoin chain data pipelines processing hundreds of gigabytes per day with
              BigQuery, dbt, Dagster, GCP, Kubernetes, and open-source tooling.
            </li>
            <li>
              Created core Filecoin analytical models abstracted from raw indexer schemas, improving reliability,
              queryability, and reuse across dashboards, stakeholder requests, and feature impact analysis.
            </li>
            <li>
              Productionized the data warehouse, dbt, CI/CD, tests, freshness checks, and documentation for
              organization-wide analytics workflows.
            </li>
            <li>
              Improved dashboards and reporting used weekly by leadership and ecosystem stakeholders, surfacing data
              quality issues in Lily, JSON-RPC, indexing, and provider datasets.
            </li>
            <li>
              Built open data portals and reusable artifacts that helped external teams self-serve Filecoin metrics
              instead of depending on private requests.
            </li>
          </ul>
        </article>

        <article class="item">
          <header>
            <h3><a href="https://buffer.com">Buffer</a></h3>
            <p class="meta"><time datetime="2017-05">May 2017</time> – <time datetime="2022-03">Mar 2022</time></p>
          </header>
          <p><strong>Sr. Data Engineer</strong></p>
          <p>Evolved Buffer's data architecture and tooling to make data actionable:</p>
          <ul>
            <li>
              Architected and migrated Buffer's data platform to a <a
                href="https://www.speedwins.tech/posts/data-at-buffer-with-david-gasquez">modern stack</a
              >, moving databases and services to GCP with no downtime and lower costs.
            </li>
            <li>
              Built tooling for Buffer's <a href="https://github.com/bufferapp/README/tree/master/teams/data/docs/buda"
                >data streaming architecture</a
              >, including <a href="https://pypistats.org/packages/kiner">kiner</a> and <a
                href="https://pypistats.org/packages/stacklogging">stacklogging</a
              >.
            </li>
            <li>
              Improved data scientist UX with <a
                href="https://github.com/davidgasquez?tab=repositories&q=dbt&type=&language=&sort="
                >dbt local setup, CI/CD, tests, and modeling practices</a
              >.
            </li>
            <li>
              Modeled social product behavior across publishing flows, channel connections, key actions, funnels,
              cohorts, customer segments, and Mixpanel/Segment tracking.
            </li>
            <li>
              Analyzed retention, churn, and feature impact using survival curves, event-based analytics, derived
              events, and operational analytics.
            </li>
            <li>
              Built ML data products including <a href="https://buffer.com/resources/predicting-churn/"
                >churn prediction</a
              >, <a href="https://github.com/bufferapp/cricket">toxic comment detection</a>, and <a
                href="https://github.com/bufferapp/hashy">hashtag recommendations</a
              >.
            </li>
            <li>
              Iterated on privacy-aware data governance, PII tagging, data quality, and metric ownership practices.
            </li>
          </ul>
        </article>

        <article class="item">
          <header>
            <h3><a href="https://buffer.com">Buffer</a></h3>
            <p class="meta"><time datetime="2016-01">Jan 2016</time> – <time datetime="2017-05">May 2017</time></p>
          </header>
          <p><strong>Data Analyst</strong></p>
          <p>
            Used data to answer stakeholder questions and built a Docker-based analytics stack to make analysis
            reproducible and improve developer experience.
          </p>
        </article>

        <article class="item">
          <header>
            <h3><a href="https://nucleoo.com">Nucleoo</a></h3>
            <p class="meta"><time datetime="2015-04">Apr 2015</time> – <time datetime="2016-01">Jan 2016</time></p>
          </header>
          <p><strong>Software Developer</strong></p>
          <p>
            Built backend features for a business intelligence application focused on data analysis and machine
            learning. Worked with Flask, MongoDB, pandas, NumPy, and scikit-learn.
          </p>
        </article>
      </section>

      <section aria-labelledby="skills">
        <h2 id="skills">Skills</h2>
        <dl class="skills">
          <div>
            <dt>Product & BI</dt>
            <dd>
              Product analytics, executive dashboards, KPI design, feature impact analysis, funnels, cohorts, retention,
              churn, and experimentation.
            </dd>
          </div>
          <div>
            <dt>Data Modeling</dt>
            <dd>
              SQL (DuckDB, BigQuery, PostgreSQL), dbt, dimensional and event modeling, data quality, metric definitions,
              reverse ETL, PII-aware governance, and BI semantic layers.
            </dd>
          </div>
          <div>
            <dt>Programming</dt>
            <dd>Python, notebooks, pandas, DuckDB, APIs, automation, data pipelines, and open data tooling.</dd>
          </div>
          <div>
            <dt>ML & Statistics</dt>
            <dd>
              Survival analysis, causal impact, scikit-learn, XGBoost, transformers, embeddings, recommendations,
              spam/anomaly detection, and graph analysis.
            </dd>
          </div>
          <div>
            <dt>Platforms</dt>
            <dd>Looker, Metabase, Redash, Mixpanel, Segment, Customer.io, GCP, Kubernetes, Dagster, Airflow, Argo.</dd>
          </div>
          <div>
            <dt>Open Protocols</dt>
            <dd>
              AT Protocol, Bluesky APIs, Lexicons, DIDs, AT URIs, CIDs, PDS/Relay/AppView architecture, git, IPFS, and
              Blockchains.
            </dd>
          </div>
        </dl>
      </section>

      <section aria-labelledby="selected-work">
        <h2 id="selected-work">Selected Work</h2>
        <ul class="projects">
          <li>
            <strong><a href="https://davidgasquez.github.io/datadex/">Datadex</a></strong>
            <p>Data platform for open data collaboration using modern open source tools.</p>
          </li>
          <li>
            <strong><a href="https://godatathon.com/">Novartis Datathon Winner</a></strong>
            <p>First place in a weekend-long data science challenge on financial data.</p>
          </li>
          <li>
            <strong><a href="https://publish.obsidian.md/davidgasquez/Data/Data+Culture">Data Handbook</a></strong>
            <p>Evergreen notes about data, teamwork, and life.</p>
          </li>
          <li>
            <strong><a href="https://datonic.io/">Datonic</a></strong>
            <p>A project to improve how people produce, share, consume, and collaborate on datasets.</p>
          </li>
          <li>
            <strong><a href="https://github.com/davidgasquez/kaggle-airbnb">Kaggle Bronze Medalist</a></strong>
            <p>Top 5% in the Airbnb Kaggle competition with a simple data preprocessing focused approach.</p>
          </li>
        </ul>
      </section>

      <section aria-labelledby="education">
        <h2 id="education">Education</h2>
        <p>Bachelor's Degree in Computer Science, <strong>UGR</strong> · 2011–2017</p>
      </section>
    </main>
  </body>
</html>

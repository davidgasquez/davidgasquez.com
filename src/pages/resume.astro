---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>David Gasquez</title>

    <style is:global>
      :root {
        --ink: #24292e;
        --muted: #6a737d;
        --accent: #770000;
        --rule: #e6e6e6;
        --paper: #fdfdfc;
      }

      body {
        color: var(--ink);
        background: var(--paper);
        line-height: 1.55;
        font-family:
          ui-sans-serif,
          system-ui,
          -apple-system,
          BlinkMacSystemFont,
          "Segoe UI",
          sans-serif;
        font-size: 15px;
        max-width: 760px;
        margin: 48px auto;
        padding: 0 32px;
        overflow-wrap: break-word;
        -webkit-font-smoothing: antialiased;
      }

      a {
        color: var(--accent);
        text-decoration: none;
        text-underline-offset: 0.18em;
      }

      a:hover,
      a:focus-visible {
        text-decoration: underline;
      }

      a:focus-visible {
        outline: 2px solid rgba(119, 0, 0, 0.45);
        outline-offset: 3px;
      }

      h1,
      h2,
      h3,
      h4,
      h5,
      h6 {
        font-weight: 650;
        line-height: 1.2;
        margin: 28px 0 12px;
      }

      h1,
      h2 {
        border-bottom: 1px solid var(--rule);
        padding-bottom: 0.32em;
      }

      h1 {
        font-size: clamp(2rem, 6vw, 2.7rem);
        letter-spacing: -0.035em;
        margin-top: 0;
      }

      h2 {
        color: #30363d;
        font-size: 1.35rem;
        letter-spacing: -0.015em;
      }

      h3 {
        font-size: 1.15rem;
      }

      h4 {
        font-size: 1rem;
      }

      h5 {
        font-size: 0.875rem;
      }

      h6 {
        color: var(--muted);
        font-size: 0.85rem;
      }

      p,
      ul,
      ol {
        margin: 0.75rem 0;
      }

      ol,
      ul {
        padding-left: 1.5rem;
      }

      li + li {
        margin-top: 0.35rem;
      }

      li > ul,
      li > ol {
        margin-top: 0.35rem;
      }

      ::selection {
        background: #f2d8d8;
      }

      @media (max-width: 640px) {
        body {
          font-size: 14px;
          margin: 24px auto;
          padding: 0 20px;
        }
      }
    </style>
  </head>

  <body>
    <main>
      <h1>David Gasquez</h1>

      <p>
        Engineer passionate about data, open source, and distributed/remote teams. Helping people coordinate better
        through data at <a href="https://protocol.ai/">Protocol Labs</a>.
        <br />
      </p>

      <p>
        {
          contactLinks.map(([label, href], index) => (
            <>
              <a href={href}>{label}</a>
              {index < contactLinks.length - 1 && " - "}
            </>
          ))
        }
      </p>

      <h2>Experience</h2>
      <ul>
        {
          experience.map(({ company, url, role, dates, intro, bullets }) => (
            <li>
              <strong>
                <a href={url}>{company}</a>: {role}
              </strong>
              . ({dates})
              <br />
              {intro}
              {bullets && (
                <ul>
                  {bullets.map((bullet) => (
                    <li set:html={bullet} />
                  ))}
                </ul>
              )}
            </li>
          ))
        }
      </ul>

      <h2>Skills</h2>
      <ul>
        {
          skills.map(([name, description]) => (
            <li>
              <strong>{name}</strong>: {description}
            </li>
          ))
        }
      </ul>

      <h2>Projects</h2>
      <ul>
        {
          projects.map(({ title, url, description }) => (
            <li>
              <strong>{url ? <a href={url}>{title}</a> : title}</strong>: <Fragment set:html={description} />
            </li>
          ))
        }
      </ul>

      <h2>Education</h2>
      <ul>
        <li>Bachelor's Degree in Computer Science. <strong> UGR </strong>. <em> (2011 - 2017) </em></li>
      </ul>
    </main>
  </body>
</html>
